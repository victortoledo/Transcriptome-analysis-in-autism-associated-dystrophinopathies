## Differential expression in NSC cells: control x DMD "pure"

Controls: F07007, F014932, F012262-4  
DMD patients without TEA: C023903, C026484, F012161-1

```{r  warning = TRUE}
# build the samples manually to change everything easily
setwd("/PROJECT_DIR/RSEM_quant/")
samples <- data.frame(sample = as.factor(gsub("(.+?)(\\_.*)", "\\1", list.files(pattern = ".genes.results"))),
                      condition=c("control","control","control","control",rep("patient",6),rep("control",2),rep("patient",6)),
                      mut_type=c(rep("none",4),"duplication","deletion","deletion","indel","deletion","snv",
                                 "none","none","duplication","deletion","deletion","indel","deletion","snv"),
                      TEA=c(rep("no",7),rep("yes",3),rep("no",5),rep("yes",3)),
                      individual=c("F07007","F07007","F014932","F012262-4","C023903","C026484","F012161-1","C026023","F012161-4",
                                   "C026786","F014932","F012262-4","C023903","C026484","F012161-1","C026023","F012161-4","C026786"),
                      new_name=c("C1","C1","C2","C3","P1","P2","P3","P4","P5","P6","C2","C3","P1","P2","P3","P4","P5","P6"),
                      age=c(27,27,25,9,16,20,20,15,20,14,25,9,16,20,20,15,20,14),
                      cell_type=c("NSC",rep("neuron",9),rep("NSC",8)))
samples$data <- paste(samples$new_name,samples$cell_type,sep="_")
#samples$group <- paste(samples$DMD_condition,samples$TEA,sep="")

files <- list.files(pattern = ".genes.results")
names(files) <- samples$sample
all(file.exists(files))

setwd("/PROJECT_DIR/RSEM_quant/")

samples_nsc <- samples[samples$cell_type == "NSC",]

samples_nsc1 <- samples_nsc[1:6,] 

files_nsc1 <- files[c(1,11:15)]
all(file.exists(files_nsc1))

txi = tximport(files_nsc1, type = "rsem", txIn = FALSE, txOut = FALSE)
# we tested two lengths (0.01 and 1) and the results were different
txi$length[txi$length == 0] = 1

ddsColl <- DESeqDataSetFromTximport(txi, colData = samples_nsc1, design = ~condition)

#ddsColl <- collapseReplicates(dds, dds$individual, dds$sample)

smallestGroupSize <- 3
keep <- rowSums(counts(ddsColl) >= 250) >= smallestGroupSize
table(keep)
ddsColl <- ddsColl[keep,]
ddsColl <- DESeq(ddsColl)
resultsNames(ddsColl)
res_noShrink <- results(ddsColl, name="condition_patient_vs_control",alpha = 0.05)
summary(res_noShrink)

# shrinkage of effect size (LFC estimates) is useful for visualization and ranking of genes.
res <- lfcShrink(ddsColl, coef ="condition_patient_vs_control", type = "apeglm", svalue = T)
summary(res)
```

```{r  warning = TRUE}
# From the results() function to get the outlier genes
m <- nrow(attr(ddsColl, "dispModelMatrix"))
p <- ncol(attr(ddsColl, "dispModelMatrix"))
cooksCutoff <- qf(0.99, p, m - p)
cooksOutlier <- mcols(ddsColl)$maxCooks > cooksCutoff

w <- which(cooksOutlier)

# these are the outliers, four as reported in summary(res)
rownames(ddsColl)[w]
```

```{r  warning = TRUE}
formated_res <- as.data.frame(res) %>%
  rownames_to_column("gene") %>%
  arrange(desc(abs(log2FoldChange))) %>%
  mutate(significative = if_else(svalue < 0.005, "yes", "no")) %>%
  mutate(up = if_else(log2FoldChange < 0, "control", "patient"))
#formated_res <- merge(formated_res, anot_table, by.x = "gene", by.y = "ensembl_gene_id", all.x = T)
paged_table(formated_res)

formated_res_noShrink <- as.data.frame(res_noShrink) %>%
  rownames_to_column("gene") %>%
  arrange(desc(abs(log2FoldChange))) %>%
  mutate(significative = if_else(padj < 0.05, "yes", "no")) %>%
  mutate(up = if_else(log2FoldChange < 0, "control", "patient"))
##formated_res_noShrink <- merge(formated_res_noShrink, anot_table, by.x = "gene", by.y = "ensembl_gene_id", all.x = T)

paged_table(formated_res)

formated_res$symbol <- gsub(".*_","",formated_res$gene)
formated_res_noShrink$symbol <- gsub(".*_","",formated_res_noShrink$gene)

NSC_control_nTEA_sig <- formated_res[formated_res$significative == "yes",]
NSC_control_nTEA_downreg <- NSC_control_nTEA_sig[NSC_control_nTEA_sig$up == "control",]
NSC_control_nTEA_upreg <- NSC_control_nTEA_sig[NSC_control_nTEA_sig$up == "patient",]

write.table(formated_res, file = "/PROJECT_DIR/diff_exp/NSC_control_nTEA_shrink_results.txt", row.names = FALSE, sep = "\t", quote = FALSE)
write.table(NSC_control_nTEA_downreg, file = "/PROJECT_DIR/diff_exp/NSC_control_nTEA_downreg_shrink_results.txt", row.names = FALSE, sep = "\t", quote = FALSE)
write.table(NSC_control_nTEA_upreg, file = "/PROJECT_DIR/diff_exp/NSC_control_nTEA_upreg_shrink_results.txt", row.names = FALSE, sep = "\t", quote = FALSE)
write.table(formated_res_noShrink, file = "/PROJECT_DIR/diff_exp/NSC_control_nTEA_results.txt", row.names = FALSE, sep = "\t", quote = FALSE)
```

